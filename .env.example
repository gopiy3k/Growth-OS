# Growth OS environment (placeholders only — never commit real secrets)

# --- Growth OS Supabase (platform-owned database) ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-service-role-key

# --- AI Runtime (any implementation speaking the OpenAI-compatible contract) ---
# These are the ONLY runtime facts the EOS reads (ADR-022). Never name a model/provider here.
AI_RUNTIME_BASE_URL=http://127.0.0.1:8643/v1
AI_RUNTIME_API_KEY=demo
# AI_RUNTIME_MODEL is runtime-published TELEMETRY only. Leave empty in EOS config.
AI_RUNTIME_MODEL=

# --- Buffer (Content Engine publish transport: Buffer Developer API / GraphQL) ---
# Get a key: https://publish.buffer.com/settings/api  (Settings -> API -> New Key)
# The key is a Bearer token sent as `Authorization: Bearer <key>` to https://api.buffer.com
BUFFER_ACCESS_TOKEN=your-buffer-developer-api-key
# Channel ids (legacy API called these "profile" ids). Discover via the API:
#   query { channels(input: { organizationId: "<org>" }) { id name service } }
BUFFER_LINKEDIN_PROFILE_ID=your-linkedin-channel-id
BUFFER_X_PROFILE_ID=your-x-channel-id

