# Growth OS environment (placeholders only — never commit real secrets)

# --- Growth OS Supabase (platform-owned database) ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-service-role-key

# --- AI Runtime (any implementation speaking the OpenAI-compatible contract) ---
# These are the ONLY runtime facts the EOS reads (ADR-022). Never name a model/provider here.
AI_RUNTIME_BASE_URL=http://127.0.0.1:8643/v1
AI_RUNTIME_API_KEY=demo
# AI_RUNTIME_MODEL is runtime-published TELEMETRY only. Leave empty in EOS config.
AI_RUNTIME_MODEL=
